all: all-am

.SUFFIXES:
.SUFFIXES: .c .o .obj
$(srcdir)/Makefile.in: @MAINTAINER_MODE_TRUE@ $(srcdir)/Makefile.am $(top_srcdir)/m4/diet.am $(srcdir)/testsuite/Makefile-files $(am__configure_deps)
	@for dep in $?; do \
	  case '$(am__configure_deps)' in \
	    *$$dep*) \
	      cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh \
		&& exit 0; \
	      exit 1;; \
	  esac; \
	done; \
	echo ' cd $(top_srcdir) && $(AUTOMAKE) --gnits  src/Makefile'; \
	cd $(top_srcdir) && \
	  $(AUTOMAKE) --gnits  src/Makefile
.PRECIOUS: Makefile
Makefile: $(srcdir)/Makefile.in $(top_builddir)/config.status
	@case '$?' in \
	  *config.status*) \
	    cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh;; \
	  *) \
	    echo ' cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__depfiles_maybe)'; \
	    cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__depfiles_maybe);; \
	esac;

$(top_builddir)/config.status: $(top_srcdir)/configure $(CONFIG_STATUS_DEPENDENCIES)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh

$(top_srcdir)/configure: @MAINTAINER_MODE_TRUE@ $(am__configure_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(ACLOCAL_M4): @MAINTAINER_MODE_TRUE@ $(am__aclocal_m4_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh

clean-checkLIBRARIES:
	-test -z "$(check_LIBRARIES)" || rm -f $(check_LIBRARIES)
libenscsentinel.a: $(libenscsentinel_a_OBJECTS) $(libenscsentinel_a_DEPENDENCIES) 
	-rm -f libenscsentinel.a
	$(libenscsentinel_a_AR) libenscsentinel.a $(libenscsentinel_a_OBJECTS) $(libenscsentinel_a_LIBADD)
	$(RANLIB) libenscsentinel.a

clean-checkPROGRAMS:
	-test -z "$(check_PROGRAMS)" || rm -f $(check_PROGRAMS)
install-sbinPROGRAMS: $(sbin_PROGRAMS)
	@$(NORMAL_INSTALL)
	$(mkdir_p) $(DESTDIR)$(sbindir)
	@list='$(sbin_PROGRAMS)'; for p in $$list; do \
	  p1=`echo $$p|sed 's/$(EXEEXT)$$//'`; \
	  if test -f $$p \
	  ; then \
	    f=`echo "$$p1" | sed 's,^.*/,,;$(transform);s/$$/$(EXEEXT)/'`; \
	   echo " $(INSTALL_PROGRAM_ENV) $(sbinPROGRAMS_INSTALL) $$p $(DESTDIR)$(sbindir)/$$f"; \
	   $(INSTALL_PROGRAM_ENV) $(sbinPROGRAMS_INSTALL) $$p $(DESTDIR)$(sbindir)/$$f || exit 1; \
	  else :; fi; \
	done

uninstall-sbinPROGRAMS:
	@$(NORMAL_UNINSTALL)
	@list='$(sbin_PROGRAMS)'; for p in $$list; do \
	  f=`echo "$$p" | sed 's,^.*/,,;s/$(EXEEXT)$$//;$(transform);s/$$/$(EXEEXT)/'`; \
	  echo " rm -f $(DESTDIR)$(sbindir)/$$f"; \
	  rm -f $(DESTDIR)$(sbindir)/$$f; \
	done

clean-sbinPROGRAMS:
	-test -z "$(sbin_PROGRAMS)" || rm -f $(sbin_PROGRAMS)

installcheck-sbinPROGRAMS: $(sbin_PROGRAMS)
	bad=0; pid=$$$$; list="$(sbin_PROGRAMS)"; for p in $$list; do \
	  case ' $(AM_INSTALLCHECK_STD_OPTIONS_EXEMPT) ' in \
	   *" $$p "* | *" $(srcdir)/$$p "*) continue;; \
	  esac; \
	  f=`echo "$$p" | \
	     sed 's,^.*/,,;s/$(EXEEXT)$$//;$(transform);s/$$/$(EXEEXT)/'`; \
	  for opt in --help --version; do \
	    if $(DESTDIR)$(sbindir)/$$f $$opt > c$${pid}_.out 2> c$${pid}_.err \
		 && test -n "`cat c$${pid}_.out`" \
		 && test -z "`cat c$${pid}_.err`"; then :; \
	    else echo "$$f does not support $$opt" 1>&2; bad=1; fi; \
	  done; \
	done; rm -f c$${pid}_.???; exit $$bad
testsuite/$(am__dirstamp):
	@$(mkdir_p) testsuite
	@: > testsuite/$(am__dirstamp)
testsuite/$(DEPDIR)/$(am__dirstamp):
	@$(mkdir_p) testsuite/$(DEPDIR)
	@: > testsuite/$(DEPDIR)/$(am__dirstamp)
testsuite/blacklist_check-blacklist-check.$(OBJEXT):  \
	testsuite/$(am__dirstamp) testsuite/$(DEPDIR)/$(am__dirstamp)
blacklist-check$(EXEEXT): $(blacklist_check_OBJECTS) $(blacklist_check_DEPENDENCIES) 
	@rm -f blacklist-check$(EXEEXT)
	$(LINK) $(blacklist_check_LDFLAGS) $(blacklist_check_OBJECTS) $(blacklist_check_LDADD) $(LIBS)
testsuite/blacklist_parser-blacklist-parser.$(OBJEXT):  \
	testsuite/$(am__dirstamp) testsuite/$(DEPDIR)/$(am__dirstamp)
blacklist-parser$(EXEEXT): $(blacklist_parser_OBJECTS) $(blacklist_parser_DEPENDENCIES) 
	@rm -f blacklist-parser$(EXEEXT)
	$(LINK) $(blacklist_parser_LDFLAGS) $(blacklist_parser_OBJECTS) $(blacklist_parser_LDADD) $(LIBS)
ip-sentinel$(EXEEXT): $(ip_sentinel_OBJECTS) $(ip_sentinel_DEPENDENCIES) 
	@rm -f ip-sentinel$(EXEEXT)
	$(LINK) $(ip_sentinel_LDFLAGS) $(ip_sentinel_OBJECTS) $(ip_sentinel_LDADD) $(LIBS)
testsuite/prioqueue_check-prioqueue-check.$(OBJEXT):  \
	testsuite/$(am__dirstamp) testsuite/$(DEPDIR)/$(am__dirstamp)
prioqueue-check$(EXEEXT): $(prioqueue_check_OBJECTS) $(prioqueue_check_DEPENDENCIES) 
	@rm -f prioqueue-check$(EXEEXT)
	$(LINK) $(prioqueue_check_LDFLAGS) $(prioqueue_check_OBJECTS) $(prioqueue_check_LDADD) $(LIBS)
testsuite/simulate-simulate.$(OBJEXT): testsuite/$(am__dirstamp) \
	testsuite/$(DEPDIR)/$(am__dirstamp)
simulate$(EXEEXT): $(simulate_OBJECTS) $(simulate_DEPENDENCIES) 
	@rm -f simulate$(EXEEXT)
	$(LINK) $(simulate_LDFLAGS) $(simulate_OBJECTS) $(simulate_LDADD) $(LIBS)

mostlyclean-compile:
	-rm -f *.$(OBJEXT)
	-rm -f testsuite/blacklist_check-blacklist-check.$(OBJEXT)
	-rm -f testsuite/blacklist_parser-blacklist-parser.$(OBJEXT)
	-rm -f testsuite/prioqueue_check-prioqueue-check.$(OBJEXT)
	-rm -f testsuite/simulate-simulate.$(OBJEXT)

distclean-compile:
	-rm -f *.tab.c


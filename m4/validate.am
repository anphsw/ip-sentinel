config.h install-data-local install-exec-local:	\
			.X$(subst /,_,$(prefix))-up-to-date

distclean-local:	distclean-uptodate

distclean-uptodate:
			@rm -f  .*-up-to-date

.%-up-to-date:
			@rm -f  .*-up-to-date
			@touch $@
			@$(MAKE)  clean
